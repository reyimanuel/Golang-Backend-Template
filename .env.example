# Port to run the application
PORT=8080 
IS_PRODUCTION=false
# Set to true for production environment
# Set to false for development environment

# Database username. Default is 'postgres'
DB_USER=postgres 
# Database password.
DB_PASS=fill-in-your-password 
# This is the name of the database.
DB_NAME=db-name 
 # Database host. using localhost
DB_HOST=127.0.0.1
# Database port. Default is 5432 for PostgreSQL
DB_PORT=5432 
# Time zone for the database connection.
DB_TIME_ZONE=Asia/Jakarta 

# Allowed origin for CORS. Set to '*' to allow all origins.
ALLOW_ORIGIN=* 

# Base URL of the application
BASE_URL=http://localhost:8080/

# Access token expiration time in seconds.
ACCESS_TOKEN_LIFE_TIME=3600 
# Refresh token expiration time in seconds.
REFRESH_TOKEN_LIFE_TIME=86400 

# Path to the private key file for JWT signing
PRIVATE_KEY=./keys/your_private_key.pem

# Path to the public key file for JWT verification
PUBLIC_KEY=./keys/your_public_key.pem

# ToDo: Change to frontend URL
FRONTEND_URL=http://localhost:3000/